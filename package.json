{
  "name": "nuxt-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:test": "NODE_ENV=test vp run build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && vp config",
    "check": "vp run check:lint && vp run check:typecheck",
    "lint": "vp lint && eslint .",
    "lint:eslint": "eslint .",
    "lint:fix": "vp lint --fix && eslint . --fix && vp fmt",
    "typecheck": "vp run check:typecheck",
    "test": "vp test",
    "test:unit": "vp test --project unit",
    "test:nuxt": "vp test --project nuxt",
    "test:browser": "vp run browser:test",
    "test:browser:ui": "vp run browser:test:ui",
    "test:e2e": "vp run browser:test",
    "test:e2e:ui": "vp run browser:test:ui",
    "test:coverage": "vp test --coverage",
    "test:a11y": "vp run audit:a11y",
    "knip": "vp run check:knip",
    "start:playwright:webserver": "vp run browser:server"
  },
  "dependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/scripts": "^0.12.0",
    "@nuxt/test-utils": "4.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/html-validator": "^2.1.0",
    "@nuxtjs/i18n": "10.2.4",
    "@nuxtjs/robots": "^5.5.6",
    "@nuxtjs/sitemap": "^7.4.7",
    "@tailwindcss/vite": "4.2.2",
    "@vite-pwa/nuxt": "1.1.1",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "nuxt": "^4.4.2",
    "nuxt-og-image": "^5.1.12",
    "tailwindcss": "4.2.2",
    "vite-plus": "0.1.12",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@nuxt/schema": "^4.4.2",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "happy-dom": "^20.8.9",
    "knip": "^5.66.2",
    "rolldown": "1.0.0-rc.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.58.0",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.12",
    "vitest-environment-nuxt": "^1.0.1",
    "vue-tsc": "^3.1.1"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.32.1"
}
